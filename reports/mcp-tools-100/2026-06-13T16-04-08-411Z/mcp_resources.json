                "content": "// Games3d_RaceCar/src/TireFriction.js\n// ES module exporting a named function and default export in one statement.\n\n/**\n * Returns a friction coefficient for a tire based on speed (km/h) and surface type.\n * @param {number} speed - Vehicle speed in km/h.\n * @param {string} surface - Surface type ('asphalt', 'gravel', 'mud', 'ice').\n * @returns {number} Friction coefficient between 0.0 and 1.0.\n */\nfunction getTireFriction(speed, surface = 'asphalt') {\n  const clamped = Math.max(0, Math.min(speed, 300));\n  const baseMap = { asphalt: 0.9, gravel: 0.6, mud: 0.4, ice: 0.2 };\n  const base = baseMap[surface] ?? baseMap['asphalt'];\n  const factor = 1 - Math.min(clamped / 200, 1) * 0.3;\n  return Math.max(0, Math.min(base * factor, 1));\n}\n\nexport { getTireFriction, getTireFriction as default };"
