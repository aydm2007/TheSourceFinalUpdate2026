# Nexus Engine V — Hybrid Intelligence Configuration
# Node A (ayman) - Primary Fallback
SILICONFLOW_API_KEY_AYMAN=your_ayman_api_key_here
# Node B (ccc) - Emergency Fallback
SILICONFLOW_API_KEY_CCC=your_ccc_api_key_here

# Active Key Priority 1
SILICONFLOW_API_KEY=your_primary_api_key_here

# Operational Matrix Settings
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
LLM_PROVIDER=siliconflow

# Unified Aether Relay routing
# Use these for OpenRouter-hosted cloud/free models from the console:
#   .\aether.ps1 console openai/gpt-oss-120b:free
#   .\aether.ps1 console openai/gpt-oss-120b:free
AETHER_PROVIDER=openrouter
AETHER_MODEL=openai/gpt-oss-120b:free
AETHER_PLANNER_MODEL=openai/gpt-oss-120b:free
AETHER_EXECUTOR_MODEL=openai/gpt-oss-120b:free
OPENROUTER_API_KEY=your_openrouter_api_key_here
AETHER_OPENROUTER_PATTERNS=:free,openai/,google/,meta/,anthropic/,qwen/

# Sovereign Engine (Gemini Flash 3)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.0-flash
NEXUS_ENGINE_SIMPLE=1
NEXUS_CONFIG_DIR=./.nexus

# MCP admin/developer keys. Keep real values only in .env or the deployment secret store.
MCP_API_KEY=replace_with_admin_mcp_key
MCP_ADMIN_API_KEY=replace_with_admin_mcp_key
MCP_DEV_API_KEY=replace_with_developer_mcp_key

# ============================================================
# 🧪 SOVEREIGN LABS — مختبر الأسراب الداخلي
# بيئة آمنة لاختبار الوكلاء ببناء أنظمة وألعاب حقيقية
# تشغيل: node labs/swarm_test_runner.js [chess-engine|todo-system|skill-forge]
# ============================================================
LABS_ROOT=./labs
LABS_ACTIVE_PROJECT=chess-engine

# ============================================================
# 🗳️ CONSENSUS GATE — بوابة التصويت والتعديل الحقيقي
# بدلاً من git commit، يصوّت N وكيل ثم يُطبَّق التعديل مباشرة
# ============================================================
CONSENSUS_THRESHOLD=2
LIVE_EDIT_MODE=true
CONSENSUS_LOG_PATH=.nexus/var/telemetry/consensus_log.jsonl

# ============================================================
# 🔄 SIMULATION MODE
# false = تعديل حقيقي مباشر (الافتراضي)
# true  = dry-run فقط (للمحاكاة والتجربة)
# ============================================================
SIMULATION_DRY_RUN=false

# ============================================================
# 🔨 SKILL FORGE — ورشة بناء المهارات ذاتياً
# ============================================================
SKILL_FORGE_PATH=./labs/skill-forge
SKILL_AUTO_VERIFY=true
