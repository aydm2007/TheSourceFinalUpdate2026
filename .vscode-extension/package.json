{
  "name": "sovereign-nervous-system",
  "displayName": "Sovereign Nervous System",
  "description": "MCP Edge integration for deep GUI/Hardware bridging.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sovereign-nervous-system.connect",
        "title": "Connect to Sovereign MCP"
      },
      {
        "command": "sovereign-nervous-system.showWebView",
        "title": "Sovereign MCP: Show WebView"
      }
    ]
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
